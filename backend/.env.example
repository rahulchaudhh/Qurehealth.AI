# Server
PORT=5001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/qurehealth

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Payment Gateway
# eSewa (Nepal) - Currently Integrated
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SUCCESS_URL=http://localhost:5173/payment/success
ESEWA_FAILURE_URL=http://localhost:5173/payment/failure

# Stripe (Optional - International)
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Khalti (Optional - Nepal Alternative)
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key

# Payment Configuration
CONSULTATION_FEE=500
COMMISSION_RATE=0.10
TAX_RATE=0.13

# Frontend URLs (for CORS)
PATIENT_URL=http://localhost:5173
DOCTOR_URL=http://localhost:5174
ADMIN_URL=http://localhost:5175
