# Server
PORT=5001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/qurehealth

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Payment (Razorpay / Stripe)
PAYMENT_KEY_ID=your_key_id
PAYMENT_KEY_SECRET=your_key_secret

# Frontend URLs (for CORS)
PATIENT_URL=http://localhost:5173
DOCTOR_URL=http://localhost:5174
ADMIN_URL=http://localhost:5175
